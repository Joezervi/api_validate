# ── Frontend environment variables ───────────────────────────────────
# Local dev:   cp sku_check_web/.env.example sku_check_web/.env
# Vercel:      set these in Vercel Dashboard → Settings → Environment Variables
#
# VITE_ prefixed vars are build-time only — they get bundled into the JS.
# They are NOT secrets. Use Vercel dashboard (not .env) for production.

# ── Backend API URL ──────────────────────────────────────────────────
# Monorepo (default): empty → API lives on same domain via api/index.py
# Separate backend:   https://your-api.vercel.app
VITE_API_BASE_URL=http://localhost:8000

# ── Gateway API credentials (used to fetch the JWT for protected routes)
VITE_API_USER=admin
VITE_API_PASSWORD=admin
VITE_API_CLIENT_ID=admin
VITE_API_CLIENT_SECRET=admin