# ── PO Checker ── Environment variables ─────────────────────────────────
# Copy this file to backend/.env and fill in your values.
#
#   cp .env.example backend/.env
#
# Priority (highest wins):
#   1. Docker Compose `environment:` block
#   2. backend/.env file
#   3. Hardcoded fallback in backend/app/config.py

# ── Database ───────────────────────────────────────────────────────────

# Docker Compose (container-to-container via service name):
DATABASE_URL=postgresql://postgres:postgres@po-postgres:5432/pochecker

# Local dev without Docker (port 5434 mapped in docker-compose.yml):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5434/pochecker

# Remote / production Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Optional ───────────────────────────────────────────────────────────

# Application port (default: 9000)
# APP_PORT=9000

# Log level (default: info)
# LOG_LEVEL=debug
