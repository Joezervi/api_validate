# ── Frontend environment variables ───────────────────────────────────
# Copy this to frontend/.env and adjust for your environment.
#
#   cp frontend/.env.example frontend/.env

# Docker dev (default) — leave empty, Vite proxy handles routing
VITE_API_BASE_URL=

# Local dev without Docker (backend running on port 9000)
# VITE_API_BASE_URL=http://localhost:9000

# Vercel production — set to your deployed backend URL
# VITE_API_BASE_URL=https://po-checker-api.vercel.app
